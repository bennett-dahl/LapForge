{
  "name": "lapforge",
  "version": "1.0.0",
  "description": "LapForge - Telemetry Analysis Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "author": "",
  "license": "PRIVATE",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.lapforge.app",
    "productName": "LapForge",
    "directories": {
      "output": "../dist/electron"
    },
    "extraResources": [
      {
        "from": "../dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bennett-dahl",
        "repo": "LapForge"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LapForge"
    }
  }
}
